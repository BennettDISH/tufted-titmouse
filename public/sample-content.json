    "label": "Activities",
    "description": "Interactive learning activities ported from the standalone embedded-activities family (portfolio/embedded-projects). Each activity type is a self-contained interaction; a project can be one activity (embed/LMS style) or a set. Type keys match component keys in src/packs/activities.",
    "version": "1.0.0",
    "preview": {
      "mode": "hosted",
      "targetUrl": "",
      "embedPath": "/?embed=1"
    },
    "entries": {
      "activitySet": {
        "key": "activitySet",
        "label": "Activity set",
        "icon": "🎒",
        "category": "Structure",
        "description": "A titled collection of activities shown one after another.",
        "aiGuidance": "Use only when combining several activities into one page; a single-activity project should use that activity as the root directly. Keep the intro to one sentence.",
        "allowAtRoot": true,
        "allowedChildTypeKeys": [
          "matching",
          "compareSlider",
          "speedSort"
        ],
        "schema": {
          "title": {
            "type": "string",
            "label": "Title",
            "required": true,
            "maxLength": 80
          },
          "intro": {
            "type": "text",
            "label": "Intro",
            "hint": "Shown above the activities."
          }
        },
        "template": {
          "title": "Practice activities",
          "intro": ""
        }
      },
      "matching": {
        "key": "matching",
        "label": "Matching",
        "icon": "🧩",
        "category": "Activities",
        "description": "Match each concept to its example — pair up, submit, get graded.",
        "aiGuidance": "4-6 pairs. Sources are short concepts (1-4 words); targets are one-sentence examples or definitions that clearly belong to exactly one source. Avoid targets that could plausibly match two sources.",
        "allowAtRoot": true,
        "allowedChildTypeKeys": [],
        "schema": {
          "title": {
            "type": "string",
            "label": "Title",
            "required": true,
            "maxLength": 80
          },
          "introText": {
            "type": "text",
            "label": "Instructions",
            "hint": "One sentence telling the learner what to do."
          },
          "sourceLabel": {
            "type": "string",
            "label": "Left column label"
          },
          "targetLabel": {
            "type": "string",
            "label": "Right column label"
          },
          "pairs": {
            "type": "array",
            "label": "Pairs",
            "minItems": 2,
            "maxItems": 8,
            "itemSchema": {
              "source": {
                "type": "string",
                "label": "Concept",
                "required": true
              },
              "target": {
                "type": "text",
                "label": "Its match",
                "required": true
              }
            }
          },
          "shuffleTargets": {
            "type": "boolean",
            "label": "Shuffle the right column"
          },
          "successMessage": {
            "type": "string",
            "label": "All-correct message",
            "editorTab": "feedback"
          },
          "partialMessage": {
            "type": "string",
            "label": "Some-wrong message",
            "editorTab": "feedback"
          }
        },
        "template": {
          "title": "Concept Matching",
          "introText": "Match each concept on the left to its example on the right.",
          "sourceLabel": "Concepts",
          "targetLabel": "Examples",
          "pairs": [
            {
              "source": "Primary Colors",
              "target": "Red, Blue, Yellow — the fundamental colors that cannot be created by mixing other colors."
            },
            {
              "source": "Renewable Energy",
              "target": "Solar, Wind, Hydroelectric — energy sources that naturally replenish over time."
            },
            {
              "source": "Programming Languages",
              "target": "JavaScript, Python, Java — languages used to create software applications."
            },
            {
              "source": "Geometric Shapes",
              "target": "Triangle, Circle, Square — basic two-dimensional shapes with defined properties."
            }
          ],
          "shuffleTargets": true,
          "successMessage": "Excellent work! You matched every concept correctly.",
          "partialMessage": "Good effort — review the red pairs and try again."
        }
      },
      "compareSlider": {
        "key": "compareSlider",
        "label": "Compare slider",
        "icon": "🎚️",
        "category": "Activities",
        "description": "Slide between two concepts and read how the balance shifts; multiple themes.",
        "aiGuidance": "2-4 themes. Each theme is a genuine tension (speed vs quality), not opposites like good vs bad. The three descriptions must actually differ: left praises one extreme, right the other, center describes the blend. Icons are single emoji; colors are contrasting hexes.",
        "allowAtRoot": true,
        "allowedChildTypeKeys": [],
        "schema": {
          "title": {
            "type": "string",
            "label": "Title",
            "required": true,
            "maxLength": 80
          },
          "description": {
            "type": "text",
            "label": "Instructions"
          },
          "themes": {
            "type": "array",
            "label": "Comparison themes",
            "minItems": 1,
            "maxItems": 5,
            "itemSchema": {
              "name": {
                "type": "string",
                "label": "Theme name",
                "required": true
              },
              "leftConcept": {
                "type": "string",
                "label": "Left concept",
                "required": true
              },
              "rightConcept": {
                "type": "string",
                "label": "Right concept",
                "required": true
              },
              "leftIcon": {
                "type": "string",
                "label": "Left emoji"
              },
              "rightIcon": {
                "type": "string",
                "label": "Right emoji"
              },
              "leftColor": {
                "type": "color",
                "label": "Left color"
              },
              "rightColor": {
                "type": "color",
                "label": "Right color"
              },
              "left": {
                "type": "text",
                "label": "Left-side description",
                "required": true
              },
              "center": {
                "type": "text",
                "label": "Balanced description",
                "required": true
              },
              "right": {
                "type": "text",
                "label": "Right-side description",
                "required": true
              }
            }
          }
        },
        "template": {
          "title": "Interactive Comparison",
          "description": "Choose a theme, then drag the slider to explore the balance between two ideas.",
          "themes": [
            {
              "name": "Creativity vs Structure",
              "leftConcept": "Creative Freedom",
              "rightConcept": "Organized Structure",
              "leftIcon": "🎨",
              "rightIcon": "📋",
              "leftColor": "#e74c3c",
              "rightColor": "#3498db",
              "left": "Pure creativity emphasizes innovation, spontaneity, and unlimited artistic expression.",
              "center": "A balanced approach combines creative inspiration with organizational frameworks.",
              "right": "Structured approaches prioritize planning, consistency, and systematic execution."
            },
            {
              "name": "Speed vs Quality",
              "leftConcept": "Fast Delivery",
              "rightConcept": "High Quality",
              "leftIcon": "⚡",
              "rightIcon": "💎",
              "leftColor": "#f39c12",
              "rightColor": "#9b59b6",
              "left": "Rapid execution focuses on quick delivery and immediate results.",
              "center": "Balanced execution achieves good quality within reasonable timeframes.",
              "right": "Quality-focused approaches prioritize excellence and polished outcomes."
            }
          ]
        }
      },
      "speedSort": {
        "key": "speedSort",
        "label": "Speed sort",
        "icon": "⚡",
        "category": "Activities",
        "description": "Sort items left or right against the clock of your own reflexes — rounds, instant feedback, score.",
        "aiGuidance": "1-3 rounds of 6-10 words each. The two categories must be mutually exclusive and every word unambiguous — this is a fast-reflex activity, not a trick quiz. Keep words to 1-2 short words so they read at a glance.",
        "allowAtRoot": true,
        "allowedChildTypeKeys": [],
        "schema": {
          "title": {
            "type": "string",
            "label": "Title",
            "required": true,
            "maxLength": 80
          },
          "description": {
            "type": "text",
            "label": "Instructions"
          },
          "rounds": {
            "type": "array",
            "label": "Rounds",
            "minItems": 1,
            "maxItems": 5,
            "itemSchema": {
              "instructions": {
                "type": "string",
                "label": "Round instructions",
                "required": true
              },
              "leftCategory": {
                "type": "string",
                "label": "Left category",
                "required": true
              },
              "rightCategory": {
                "type": "string",
                "label": "Right category",
                "required": true
              },
              "words": {
                "type": "array",
                "label": "Words",
                "minItems": 2,
                "itemSchema": {
                  "text": {
                    "type": "string",
                    "label": "Word",
                    "required": true
                  },
                  "category": {
                    "type": "enum",
                    "label": "Belongs to",
                    "required": true,
                    "options": [
                      {
                        "value": "left",
                        "label": "Left category"
                      },
                      {
                        "value": "right",
                        "label": "Right category"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
